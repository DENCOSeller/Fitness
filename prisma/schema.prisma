generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name                String?
  gender              String?  // male | female
  birthDate           DateTime? @map("birth_date") @db.Date
  height              Int?     // cm
  goal                String?  // loss | gain | maintain
  targetWeight        Float?   @map("target_weight") // kg
  activityLevel       String?  @default("moderate") @map("activity_level") // sedentary | light | moderate | active
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")

  checkIns         CheckIn[]
  exercises        Exercise[]
  workouts         Workout[]
  workoutTemplates WorkoutTemplate[]
  meals            Meal[]
  bodyMetrics      BodyMetric[]
  bodyMeasurements BodyMeasurement[]
  healthDaily      HealthDaily[]
  healthWorkouts   HealthWorkout[]
  chatMessages     ChatMessage[]
  progressPhotos   ProgressPhoto[]
  aiInsights       AiInsight[]

  @@map("users")
}

model CheckIn {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  date      DateTime @db.Date
  wellbeing Int
  sleep     Int
  stress    Int
  energy    Int
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("check_ins")
}

model Exercise {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  name         String
  muscleGroup  String   @map("muscle_group")
  description  String?
  muscleGroups String?  @map("muscle_groups") // comma-separated
  equipment    String?
  difficulty   String?  // beginner | intermediate | advanced
  tips         String?
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutSets       WorkoutSet[]
  templateExercises TemplateExercise[]

  @@map("exercises")
}

model Workout {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  date        DateTime @db.Date
  type        String
  durationMin Int?     @map("duration_min")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets WorkoutSet[]

  @@map("workouts")
}

model WorkoutSet {
  id         Int      @id @default(autoincrement())
  workoutId  Int      @map("workout_id")
  exerciseId Int      @map("exercise_id")
  setOrder   Int      @map("set_order")
  reps       Int
  weight     Float
  createdAt  DateTime @default(now()) @map("created_at")

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@map("workout_sets")
}

model WorkoutTemplate {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises TemplateExercise[]

  @@map("workout_templates")
}

model TemplateExercise {
  id         Int   @id @default(autoincrement())
  templateId Int   @map("template_id")
  exerciseId Int   @map("exercise_id")
  sets       Int
  reps       Int
  weight     Float
  sortOrder  Int   @map("sort_order")

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id])

  @@map("template_exercises")
}

model Meal {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  date       DateTime @db.Date
  mealType   String   @map("meal_type")
  description String?
  photoPath  String?  @map("photo_path")
  aiAnalysis String?  @map("ai_analysis")
  calories   Int?
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meals")
}

model BodyMetric {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  date           DateTime @db.Date
  weight         Float?
  bodyFatPct     Float?   @map("body_fat_pct")
  muscleMass     Float?   @map("muscle_mass")
  bmi            Float?
  waterPct       Float?   @map("water_pct")
  leanMass       Float?   @map("lean_mass")
  bmr            Float?
  metabolicAge   Int?     @map("metabolic_age")
  screenshotPath String?  @map("screenshot_path")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("body_metrics")
}

model BodyMeasurement {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  date      DateTime @db.Date
  neck      Float?
  chest     Float?
  waist     Float?
  belly     Float?
  hips      Float?
  glutes    Float?
  thigh     Float?
  calf      Float?
  shoulder  Float?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("body_measurements")
}

model HealthDaily {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  date           DateTime @db.Date
  steps          Int?
  activeCalories Int?     @map("active_calories")
  restingHr      Int?     @map("resting_hr")
  sleepHours     Float?   @map("sleep_hours")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("health_daily")
}

model HealthWorkout {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  date        DateTime @db.Date
  type        String
  durationMin Int?     @map("duration_min")
  calories    Int?
  source      String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("health_workouts")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  sessionId String   @map("session_id")
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@map("chat_messages")
}

model ProgressPhoto {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  date       DateTime @db.Date
  photoPath  String   @map("photo_path")
  aiAnalysis String?  @map("ai_analysis")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("progress_photos")
}

model AiInsight {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  date             DateTime @db.Date
  type             String
  model            String
  promptTokens     Int?     @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")
  content          String
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}
